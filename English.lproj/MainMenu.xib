            <windowStyleMask key="styleMask" closable="YES" miniaturizable="YES" utility="YES" nonactivatingPanel="YES" HUD="YES"/>
            <windowPositionMask key="initialPositionMask" rightStrut="YES" bottomStrut="YES"/>
            <rect key="contentRect" x="1060" y="152" width="528" height="325"/>
            <rect key="screenRect" x="0.0" y="0.0" width="2560" height="1415"/>
            <view key="contentView" misplaced="YES" id="537">
                <rect key="frame" x="0.0" y="0.0" width="528" height="325"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <textField verticalHuggingPriority="750" horizontalCompressionResistancePriority="250" setsMaxLayoutWidthAtFirstLayout="YES" preferredMaxLayoutWidth="490" translatesAutoresizingMaskIntoConstraints="NO" id="540">
                        <rect key="frame" x="17" y="16" width="365" height="256"/>
                        <textFieldCell key="cell" controlSize="mini" sendsActionOnEndEditing="YES" id="541">
                            <font key="font" metaFont="system"/>
                            <mutableString key="title">FrontRowTunes {{appVersion}}
Copyright © 2013-2026 by Alex Decker. All rights reserved.
Shortcut Keys:
	w			white background
	b			black background
	f			full screen
	1,2,…		show maximized on different screens
	←, →		switch track
	space		play/pause
	t			cycle clock styles
	T			toggle clock visibility
	Option+t		toggle full-screen clock
	↵			toggle display track position as m:ss
	fn+↵		toggle display track position bar
	i, h			toggle display this info panel
	q			quit</mutableString>
                            <color key="textColor" red="1" green="1" blue="1" alpha="1" colorSpace="calibratedRGB"/>
                            <color key="backgroundColor" name="controlColor" catalog="System" colorSpace="catalog"/>
                        </textFieldCell>
                    </textField>
                </subviews>
                <constraints>
                    <constraint firstItem="540" firstAttribute="leading" secondItem="537" secondAttribute="leading" constant="19" id="Vs7-XO-RCI"/>
                    <constraint firstItem="540" firstAttribute="top" secondItem="537" secondAttribute="top" constant="16" id="YkF-me-ki3"/>
                    <constraint firstAttribute="bottom" secondItem="540" secondAttribute="bottom" constant="16" id="epB-Jv-WgW"/>
                </constraints>
            </view>
            <point key="canvasLocation" x="139" y="139.5"/>
